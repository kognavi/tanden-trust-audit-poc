{
  "name": "tanden-trust-audit-poc",
  "version": "0.1.0",
  "description": "A tamper-evident audit trail prototype for consent history, activity records, and trust events using AWS, AI, and Web3-compatible verification.",
  "type": "commonjs",
  "private": true,
  "scripts": {
    "hash": "node scripts/hash-evidence.js samples/evidence-consent.json",
    "verify": "node scripts/verify-evidence.js samples/evidence-consent.json ea1e30d81b674069d1663be70397ed3884d038381b310748d9ff88661916ea6c",
    "demo:tamper": "perl -pi -e 's/\"status\": \"granted\"/\"status\": \"revoked\"/' samples/evidence-consent.json",
    "demo:restore": "perl -pi -e 's/\"status\": \"revoked\"/\"status\": \"granted\"/' samples/evidence-consent.json",
    "demo": "npm run hash && npm run verify"
  },
  "keywords": [
    "audit-trail",
    "tamper-evident",
    "sha256",
    "aws",
    "web3",
    "ai",
    "evidence",
    "compliance",
    "trust"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
