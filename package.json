{
  "name": "tanden-trust-audit-poc",
  "version": "0.1.0",
  "description": "A tamper-evident audit trail prototype for consent history, activity records, and trust events using AWS, AI, and Web3-compatible verification.",
  "type": "commonjs",
  "private": true,
  "scripts": {
    "hash": "node scripts/hash-evidence.js samples/evidence-consent.json",
    "verify": "node scripts/verify-evidence.js samples/evidence-consent.json samples/evidence-consent.expected.sha256",
    "validate:evidence": "node scripts/validate-evidence.js samples/evidence-consent.json schemas/evidence.schema.json",
    "generate:keys": "node scripts/generate-local-keys.js",
    "sign": "node scripts/sign-evidence.js samples/evidence-consent.json",
    "verify:signature": "node scripts/verify-signature.js samples/evidence-consent.json signatures/evidence-consent.sig",
    "demo:tamper": "node scripts/tamper-evidence.js",
    "demo:restore": "git checkout -- samples/evidence-consent.json",
    "demo": "npm run validate:evidence && npm run hash && npm run verify",
    "test": "node --test tests/*.test.js",
    "test:aws:s3": "node --test tests/*.integration.js"
  },
  "keywords": [
    "audit-trail",
    "tamper-evident",
    "sha256",
    "aws",
    "web3",
    "ai",
    "evidence",
    "compliance",
    "trust"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.1085.0",
    "@aws-sdk/client-s3": "^3.1077.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "canonicalize": "^3.0.0",
    "pg": "^8.22.0"
  }
}
